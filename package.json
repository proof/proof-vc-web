{
  "name": "@proof.com/proof-vc-web",
  "version": "0.2.0",
  "description": "Web Components for Proof Digital Credentials.",
  "keywords": [
    "VC",
    "Verifiable Credentials",
    "OID4VCI",
    "OID4VCP",
    "SD-JWT-VC",
    "Selective Disclosures",
    "Proof",
    "Proof.com",
    "OAuth",
    "Web Component",
    "Custom Element"
  ],
  "homepage": "https://github.com/proof/proof-vc-web",
  "bugs": "https://github.com/proof/proof-vc-web/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proof/proof-vc-web.git"
  },
  "license": "Apache-2.0",
  "author": "Jeremie Charrier <jeremie.charrier@proof.com>",
  "sideEffects": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "jsdelivr": "./dist/proof-verify-id.min.js",
  "unpkg": "./dist/proof-verify-id.min.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "analyze": "custom-elements-manifest analyze --litelement",
    "build": "tsdown && yarn analyze",
    "check-all": "yarn format:check && yarn lint:check && yarn typecheck && yarn publint",
    "dev": "web-dev-server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "publint": "publint --pack npm",
    "test": "yarn build && yarn test:node && yarn test:browser",
    "test:browser": "web-test-runner",
    "test:node": "node --test \"test/node/**/*.test.mjs\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@proof.com/proof-vc-common": "^0.2.0",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lit/react": "^1.0.8",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.2.17",
    "@web/dev-server": "^0.4.6",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "eslint": "^10.5.0",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-wc": "^3.1.0",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "peerDependencies": {
    "@lit/react": "^1",
    "@types/react": "^17 || ^18 || ^19",
    "react": "^17 || ^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@lit/react": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.17.0",
  "publishConfig": {
    "access": "public"
  },
  "customElements": "dist/custom-elements.json"
}
