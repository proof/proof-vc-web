{
  "private": true,
  "description": "Test website for the @proof.com/proof-vc-web Web Component.",
  "author": "Jeremie Charrier <jeremie.charrier@proof.com>",
  "type": "module",
  "scripts": {
    "build": "yarn run webpack",
    "check-all": "yarn format && yarn lint && yarn typecheck",
    "dev": "yarn run webpack serve",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "html-webpack-plugin": "^5.6.5",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "ts-loader": "^9.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  }
}
